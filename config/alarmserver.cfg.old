[alarmserver]
#logfile=/var/AlarmServer/log/alarmserver.log
logurlrequests=True
certfile=
keyfile=
maxevents=10
maxallevents=100
http=False
https=False
httpsport=8111
eventtimeago=True
## Name of your partition(s)
partition1=HOME

## Zone names. Define only your active ones; comment out unused to hide.
zone1=A
zone2=B
zone3=C
zone4=D
zone5=E
zone6=F
zone7=G
zone8=H
zone9=I
zone10=J
zone11=K
zone12=L
zone13=M
zone14=N
zone15=O
zone16=P


[pushover]
enable=False
usertoken=tokengoeshere

[ifttt_maker]
enable=False
key=keygoeshere
eventName=eventnamegoeshere

[smartthings]
enable=False
url_base=https://graph.api.smartthings.com/api/smartapps/installations
app_id=appidgoeshere
access_token=accesstokengoeshere
event_codes=601,602,609,610,650,651,652,654,656,657

[envisalink]
host=EVL_IP
port=EVL_PORT
pass=EVL_USERNAME
keepalive=60
enableproxy=True
proxyport=EVL_PROXY_PORT
proxypass=EVL_PROXY_USERNAME
alarmcode=EVL_ALARMCODE
commandtimeout=60
kpeventtimeout=90
